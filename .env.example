# ─────────────────────────────────────────────
#  .env.example  —  copy to .env and fill in
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=development          # development | production
DEMO_MODE=true               # true = use sample data, false = live scrape + DB
DEFAULT_PINCODE=110001       # Delhi pincode

# ── Kafka ─────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=raw-prices
KAFKA_TOPIC_CLEAN=clean-prices
KAFKA_TOPIC_ML=ml-scores
KAFKA_TOPIC_SEARCH=search-events
KAFKA_GROUP_ID=price-compare-group

# ── MySQL ────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=priceuser
MYSQL_PASSWORD=PriceCompare@123
MYSQL_RAW_DB=raw_store
MYSQL_CLEAN_DB=clean_store

# ── Spark ────────────────────────────────────
SPARK_MASTER=local[*]
SPARK_APP_NAME=PriceCompareStream
SPARK_BATCH_INTERVAL_SECS=10

# ── MLflow ───────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT=price-compare-deals

# ── ML API ───────────────────────────────────
ML_API_HOST=localhost
ML_API_PORT=8000

# ── Proxy (optional, for anti-bot) ───────────
PROXY_LIST=                  # comma-separated: host:port:user:pass
USE_PROXIES=false

# ── Scraper Delays ───────────────────────────
MIN_DELAY_SECS=1.5
MAX_DELAY_SECS=4.0
MAX_RETRIES=3
